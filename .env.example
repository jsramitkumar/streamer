# Copy this file to .env and adjust values before running docker-compose

# ── Docker Hub (used by GitHub Actions + optional pre-built image pull) ────────
# Set DOCKERHUB_USERNAME as a GitHub repo variable (Settings → Variables → Actions)
# Set DOCKERHUB_TOKEN   as a GitHub repo secret  (Settings → Secrets → Actions)
DOCKERHUB_USERNAME=youruser

# Ports exposed on the host
FRONTEND_PORT=8080        # dashboard + API + WebSocket (all served by backend)
BACKEND_UDP_PORT=5000     # ESP32-CAM UDP ingest (LAN only)
MQTT_PORT=1883

# MQTT credentials (leave blank for anonymous access)
MQTT_USER=
MQTT_PASS=

# AI model (must be a valid ultralytics YOLO model name or path inside container)
AI_MODEL_PATH=yolov8n.pt
AI_CONF_THRESH=0.40

# Fraction of frames forwarded to the AI service (0.0 – 1.0)
AI_SAMPLE_RATE=0.33

# Recording segment length in seconds
SEG_TIME=300

# Max UDP frame size in bytes (default 5 MB)
MAX_FRAME_BYTES=5242880

# CORS origin for the backend API (* = allow all, restrict in production)
CORS_ORIGIN=*

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# cloudflared is managed as a separate existing container.
# Point your CF tunnel public hostname at one of:
#   - http://frontend:80          (if cloudflared shares the "streamer" Docker network)
#   - http://localhost:8080        (host port, set FRONTEND_PORT below)
# The nginx proxy handles /api/* and /ws/* automatically.
